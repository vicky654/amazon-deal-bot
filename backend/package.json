{
  "name": "deal-system-backend",
  "version": "1.0.0",
  "description": "Multi-platform deal automation backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --runInBand --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "jest --runInBand --coverage --config jest.config.js",
    "test:unit": "jest --runInBand --testPathPattern=\"(affiliate|scraper|queue)\" --config jest.config.js",
    "test:api": "jest --runInBand --testPathPattern=\"api\\.\" --config jest.config.js",
    "test:integration": "jest --runInBand --testPathPattern=\"integration\" --config jest.config.js",
    "test:ci": "jest --runInBand --ci --coverage --forceExit --config jest.config.js"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "mongoose": "^8.0.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0",
    "p-queue": "^6.6.2",
    "puppeteer": "^21.6.0",
    "sharp": "^0.33.5",
    "winston": "^3.13.0"
  }
}
