# ╔══════════════════════════════════════════════════════════════════════╗
# ║              DEAL SYSTEM — BACKEND ENVIRONMENT                       ║
# ║  1. Copy this file:  cp .env.example .env                            ║
# ║  2. Fill in your values below                                        ║
# ║  3. Start server:    node server.js                                  ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free cloud DB → https://www.mongodb.com/atlas (Free Tier, no credit card)
# Or local:       mongodb://localhost:27017/deal-system
MONGODB_URI=mongodb+srv://vickydpdpconsultants_db_user:o3XzlX1yk8xxtZci@cluster0.vteutgq.mongodb.net/deal-system?retryWrites=true&w=majority

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy the token
# 2. Get chat ID: message @userinfobot  OR  visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates after adding bot to channel
TELEGRAM_TOKEN=8752176509:AAFb9MGqm1PxKwGsqrdDAgv7mti945sOn9M
TELEGRAM_CHAT=-1003897819335

# ─── Amazon Affiliate ─────────────────────────────────────────────────────────
AMAZON_TRACKING_ID=dailydeal06f0-21

# ─── EarnKaro (FULLY AUTOMATED — no manual cookie export needed) ──────────────
# After starting the server, go to Admin → Settings → EarnKaro Login
# Enter your EarnKaro email/password and click "Connect EarnKaro"
# The system will auto-login via Puppeteer, save cookies, and auto-refresh.
#
# Optional overrides (defaults shown):
EARNKARO_COOKIES_PATH=./earnkaro-cookies.json   # File fallback location
EARNKARO_HEALTHY_HOURS=12                        # Cookies fresh under this age
EARNKARO_EXPIRING_HOURS=20                       # Cookies expiring above this age
EARNKARO_REFRESH_SCHEDULE=0 */12 * * *           # Auto-refresh cron (every 12h)

# ─── Deal Thresholds ──────────────────────────────────────────────────────────
# Minimum discount % required to post a deal to Telegram
AMAZON_MIN_DISCOUNT=40
AMAZON_PRICE_DROP=30
FLIPKART_MIN_DISCOUNT=40
MYNTRA_MIN_DISCOUNT=50
AJIO_MIN_DISCOUNT=50

# ─── Crawler ──────────────────────────────────────────────────────────────────
CRON_SCHEDULE=*/5 * * * *        # How often crawler runs (every 5 min)
SCRAPE_CONCURRENCY=2
AFFILIATE_CONCURRENCY=1
SCRAPE_CACHE_TTL_MS=1800000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
