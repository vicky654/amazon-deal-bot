# ╔══════════════════════════════════════════════════════════════════════╗
# ║              DEAL SYSTEM — BACKEND ENVIRONMENT                       ║
# ║  1. Copy this file:  cp .env.example .env                            ║
# ║  2. Fill in your values below                                        ║
# ║  3. Start server:    node server.js                                  ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Supports exact domains and wildcard subdomains (*.vercel.app).
# Leave unset for open CORS (development only).
#
# Examples:
#   ALLOWED_ORIGINS=https://deal-system.vercel.app
#   ALLOWED_ORIGINS=https://deal-system.vercel.app,*.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=https://deal-system.vercel.app,*.vercel.app

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free cloud DB → https://www.mongodb.com/atlas (Free Tier, no credit card)
# Or local:       mongodb://localhost:27017/deal-system
MONGODB_URI=mongodb+srv://vickydpdpconsultants_db_user:o3XzlX1yk8xxtZci@cluster0.vteutgq.mongodb.net/deal-system?retryWrites=true&w=majority
TELEGRAM_TOKEN=8752176509:AAFb9MGqm1PxKwGsqrdDAgv7mti945sOn9M
TELEGRAM_CHAT=-1003897819335
TG_TOKEN=8752176509:AAFb9MGqm1PxKwGsqrdDAgv7mti945sOn9M
TG_CHAT_ID=-1003897819335
NEXT_PUBLIC_API_URL=http://localhost:5000

# NEXT_PUBLIC_API_URL= https://deal-system-backend.onrender.com
# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy the token
# 2. Get chat ID: message @userinfobot  OR  visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates after adding bot to channel


# ─── Amazon Affiliate ─────────────────────────────────────────────────────────
AMAZON_TRACKING_ID=dailydeal06f0-21

# ─── EarnKaro (FULLY AUTOMATED — no manual cookie export needed) ──────────────
# After starting the server, go to Admin → Settings → EarnKaro Login
# Enter your EarnKaro email/password and click "Connect EarnKaro"
# The system will auto-login via Puppeteer, save cookies, and auto-refresh.
#
# Optional overrides (defaults shown):
EARNKARO_COOKIES_PATH=./earnkaro-cookies.json   # File fallback location
EARNKARO_HEALTHY_HOURS=12                        # Cookies fresh under this age
EARNKARO_EXPIRING_HOURS=20                       # Cookies expiring above this age
EARNKARO_REFRESH_SCHEDULE=0 */12 * * *           # Auto-refresh cron (every 12h)

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT secret — change this to a random string in production!
JWT_SECRET=dealbot-admin-secret-2024
# Admin credentials (static — change before deploying)
ADMIN_EMAIL=admin@dealbot.com
ADMIN_PASSWORD=123456

# ─── Deal Thresholds ──────────────────────────────────────────────────────────
# Minimum discount % required to post a deal to Telegram
AMAZON_MIN_DISCOUNT=10
AMAZON_PRICE_DROP=10
# Minimum absolute rupee saving — deals with originalPrice - price >= this qualify even below discount threshold
AMAZON_MIN_PRICE_DROP_RS=10
FLIPKART_MIN_DISCOUNT=10
MYNTRA_MIN_DISCOUNT=10
AJIO_MIN_DISCOUNT=10

# ─── Crawler ──────────────────────────────────────────────────────────────────
CRON_SCHEDULE=*/15 * * * *       # How often crawler runs (every 15 min)
SCRAPE_CONCURRENCY=2
AFFILIATE_CONCURRENCY=1
SCRAPE_CACHE_TTL_MS=1800000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Browser Diagnostics ──────────────────────────────────────────────────────
# Set to true to pipe Chrome stderr to the Node process (useful for debugging launch failures)
DEBUG_BROWSER=false

# ─── Anti-Bot Crawler Limits ──────────────────────────────────────────────────
# Maximum Amazon pages to load per hour across all categories (budget resets hourly)
MAX_PAGES_PER_HOUR=25

# ─── Telegram Repost Engine ───────────────────────────────────────────────────
# Set to true to enable the real-time deal repost engine.
# When enabled, the server monitors source channels and reposts qualifying deals.
# Before enabling: run  node tools/telegram-login.js  to authenticate.
REPOST_ENABLED=true

# ── GramJS User Client Credentials ───────────────────────────────────────────
# Get these from: https://my.telegram.org → API Development Tools → Create App
# (Log in with your Telegram phone number, then copy API ID and API Hash)
TELEGRAM_API_ID=31957712
TELEGRAM_API_HASH=a46b939180279c6958e8ae684d6329b1

# ── Phone number (optional — used by telegram-login.js to skip the prompt) ────
TELEGRAM_PHONE=+917814239292

# ── Session (set automatically by telegram-login.js — optional manual override)
# After running  node tools/telegram-login.js  the session is saved to MongoDB.
# You can also paste the printed session string here as a fallback / for VPS deploys.
TELEGRAM_SESSION_

# ── Source channels to monitor (comma-separated, without @) ──────────────────
REPOST_SOURCE_CHANNELS=lootalertz

# ── Output channel (numeric ID with leading minus for supergroups) ────────────
REPOST_OUTPUT_CHANNEL=-1003897819335

# ── Affiliate tag to inject into reposted Amazon links ───────────────────────
REPOST_AFFILIATE_TAG=dailydeal06f0-21

# ── Quality filters — deals that don't meet ALL thresholds are skipped ────────
REPOST_MIN_DISCOUNT=40          # Minimum discount % (0 to disable)
REPOST_MIN_SAVING=300           # Minimum absolute saving in ₹ (0 to disable)
REPOST_MIN_PRICE=200            # Minimum deal price in ₹ (0 to disable)
REPOST_MAX_PRICE=50000          # Maximum deal price in ₹ (0 to disable)

# ── Block deals whose title contains any of these keywords (comma-separated) ──
REPOST_BLOCK_KEYWORDS=book,ebook,kindle,seed,diaper

# ── Hours before the same ASIN can be reposted again (dedup TTL) ─────────────
REPOST_COOLDOWN_HOURS=24
